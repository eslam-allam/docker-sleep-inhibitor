#!/bin/env bash

trap cleanup SIGINT SIGTERM

cleanup() {
    echo "Script exiting. Releasing all locks..."
    if [ -n "$INHIBIT_PID" ]; then
        kill "$INHIBIT_PID" 2>/dev/null
    fi
    exit 0
}

LABEL_KEY="system.sleep.inhibit"
LABEL_VALUE="true"
INHIBIT_PID=""

update_inhibit() {
    local TRIGGER_REASON=$1

    COUNT=$(docker ps -q --filter "label=${LABEL_KEY}=${LABEL_VALUE}" | wc -l)

    if [ "$COUNT" -gt 0 ]; then
        if [ -z "$INHIBIT_PID" ]; then
            echo "Event: $TRIGGER_REASON"
            echo "Container(s) with $LABEL_KEY=$LABEL_VALUE detected. Inhibiting sleep..."
            systemd-inhibit --what=idle:sleep \
                            --why="Docker container management" \
                            sleep infinity &
            INHIBIT_PID=$!
        fi
    else
        if [ -n "$INHIBIT_PID" ]; then
            echo "Event: $TRIGGER_REASON"
            echo "No relevant containers found. Releasing sleep lock."
            kill "$INHIBIT_PID" 2>/dev/null
            INHIBIT_PID=""
        fi
    fi
}

echo "Starting up initial scan..."
update_inhibit "Initial Scan"
echo "Watching for container events..."

docker events --filter "label=${LABEL_KEY}=${LABEL_VALUE}" --format '{{.Action}} {{index .Actor.Attributes "name"}}' | while read -r ACTION NAME; do
    update_inhibit "Container '$NAME' performed '$ACTION'"
done
